# Meta Travel — variáveis de ambiente

PORT=3000

# Amadeus Self-Service (voos + hotéis) — sandbox gratuito: https://developers.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_API_URL=https://test.api.amadeus.com

# Booking.com via RapidAPI (opcional) — https://rapidapi.com/apidojo/api/booking-com15
BOOKING_RAPIDAPI_KEY=
BOOKING_RAPIDAPI_HOST=booking-com15.p.rapidapi.com
BOOKING_AFFILIATE_ID=

# Rentalcars via RapidAPI (opcional) — deep links funcionam sem API key
RENTALCARS_RAPIDAPI_KEY=
RENTALCARS_RAPIDAPI_HOST=car-rental-api.p.rapidapi.com
RENTALCARS_AFFILIATE_ID=meta-travel

# Tracking de afiliado Meta Travel (checkout unificado)
TRAVEL_AFFILIATE_ID=meta-travel
FLIGHT_COMMISSION_PERCENT=2
HOTEL_COMMISSION_PERCENT=5
CAR_COMMISSION_PERCENT=8
ALLINCLUSIVE_COMMISSION_PERCENT=6

# Token para painel de parceiros (header X-Admin-Token)
TRAVEL_ADMIN_TOKEN=meta-travel-dev
